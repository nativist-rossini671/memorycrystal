{
  "name": "@memorycrystal/mcp-server",
  "version": "0.7.14",
  "description": "MCP server for Memory Crystal — persistent memory for AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crystal-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "CLAUDE.md",
