CONVEX_URL=https://your-deployment.convex.cloud
# Primary API key for Gemini embeddings (preferred over GEMINI_API_KEY)
CRYSTAL_API_KEY=
# Legacy fallback — still works if CRYSTAL_API_KEY is not set
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
OPENAI_API_KEY=sk-...
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
CRYSTAL_MCP_MODE=stdio
CRYSTAL_MCP_HOST=127.0.0.1
CRYSTAL_MCP_PORT=8788
EMBEDDING_PROVIDER=gemini

# MCP server env vars (used by Claude Desktop, Claude Code, Codex configs)
# These are the preferred names; legacy aliases CRYSTAL_API_KEY / CRYSTAL_BASE_URL still work.
MEMORY_CRYSTAL_API_KEY=
MEMORY_CRYSTAL_API_URL=https://your-deployment.convex.site
